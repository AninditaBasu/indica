{
  "openapi": "3.0.0",
  "info": {
    "version": "1.0.0",
    "title": "Mahabharat API",
    "description": "## Knowledge graph API for Mahabharat\nThis API returns information about people, events, and journeys.",
    "contact": {
      "email": "ab.techwriter@gmail.com"
    },
    "license": {
      "name": "MIT license",
      "url": "https://opensource.org/licenses/MIT"
    }
  },
  "externalDocs": {
    "description": "Indica APIs home",
    "url": "https://aninditabasu.github.io/indica/"
  },
  "servers": [
    {
      "url": "https://indica-1hwj.onrender.com/mb/v1",
      "description": "Mahabharat API"
    }
  ],
  "paths": {
    "/persons": {
      "get": {
        "summary": "List all persons",
        "description": "Returns a list of all persons.\n\nThe default response has names and summary information. Query parameters can be used for  obtaining fuller information.",
        "parameters": [
          {
            "name": "fields",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["basic"]
            }
          },
          {
            "name": "expand",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["true", "false"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of persons",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Person"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/persons/{name}": {
      "get": {
        "summary": "Get person by name",
        "description": "Returns information about the specified person.\n\nThe default response has summary information. Query parameters can be used for fuller information.",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "fields",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["basic"]
            }
          },
          {
            "name": "expand",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["true", "false"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Person object",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Person"
                }
              }
            }
          },
          "404": {
            "description": "Person not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/persons/{name}/armour": {
      "get": {
        "summary": "Get the panoply of a person",
        "description": "Returns a list of weapons and other implements of the specified person.",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Armour information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Armour"
                }
              }
            }
          }
        }
      }
    },
    "/persons/{name}/journeys": {
      "get": {
        "summary": "Get all journeys associated with a person",
        "description": "Returns a list of all journeys underatken by the specified person.\n\nThe default response has names and summary information. Query parameters can be used for obtaining fuller information.",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "expand",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["true", "false"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Journeys",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Journey"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/explore/{name}": {
      "get": {
        "summary": "Get complete details of a person",
        "description": "Returns information about the specified person.\n\nEvents, weapons, journeys are all reckoned.",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Aggregated exploration result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExplorePersonResponse"
                }
              }
            }
          }
        }
      }
    },
    "/weapons": {
      "get": {
        "summary": "List all weapons",
        "description": "Returns a list of all weapons.",
        "responses": {
          "200": {
            "description": "Weapons",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Weapon" }
                }
              }
            }
          }
        }
      }
    },
    "/weapons/{name}": {
      "get": {
        "summary": "Get weapon by name",
        "description": "Returns the details of the specified weapon.",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Weapon",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Weapon" }
              }
            }
          }
        }
      }
    },
    "/weapons/{name}/owners": {
      "get": {
        "summary": "List all persons owning a weapon",
        "description": "Returns a list of all persons who own the specified weapon.",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "List of person names",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "/events": {
      "get": {
        "summary": "List all events",
        "description": "Returns a list of all events.\n\nThe default response has names and summary information. Query parameters can be used for obtaining fuller information.",
        "parameters": [
          {
            "name": "fields",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["full"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Events",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Event" }
                }
              }
            }
          }
        }
      }
    },
    "/events/{name}": {
      "get": {
