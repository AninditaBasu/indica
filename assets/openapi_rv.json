{
  "openapi": "3.0.0",
  "info": {
    "version": "3.0.0",
    "title": "Rig Veda API",
    "description": "Metadata API for the Rig Veda. Makes available relationships among mandals, hymns (suktas), poets, gods, and meters.",
    "contact": {
      "email": "ab.techwriter@gmail.com"
    },
    "license": {
      "name": "CC BY-NC 4.0",
      "url": "https://creativecommons.org/licenses/by-nc/4.0/"
    }
  },
  "externalDocs": {
    "description": "Indica APIs home",
    "url": "https://aninditabasu.github.io/indica/"
  },
  "servers": [
    {
      "url": "https://indica-1hwj.onrender.com/rv/v3",
      "description": "Rig Veda API"
    }
  ],
  "paths": {
    "/mandal/{n}": {
      "get": {
        "summary": "Get the hymn count in a mandal",
        "parameters": [
          {
            "$ref": "#/components/parameters/MandalParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Hymn count in the mandal",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "mandal": {
                      "type": "integer"
                    },
                    "hymns": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid mandal"
          }
        }
      }
    },

    "/mandal/{n}/meters": {
      "get": {
        "summary": "Get the meter counts in a mandal",
        "parameters": [
          {
            "$ref": "#/components/parameters/MandalParam"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/MeterCounts"
          }
        }
      }
    },

    "/mandal/{n}/sungfor": {
      "get": {
        "summary": "Get the counts of the various gods in a mandal",
        "parameters": [
          {
            "$ref": "#/components/parameters/MandalParam"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/GodCounts"
          }
        }
      }
    },

    "/mandal/{n}/sungby": {
      "get": {
        "summary": "Get the counts of the various poets in a mandal",
        "parameters": [
          {
            "$ref": "#/components/parameters/MandalParam"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/PoetCounts"
          }
        }
      }
    },

    "/sungfor/{god}/mandals": {
      "get": {
        "summary": "Get all mandals in which a god is sung to",
        "parameters": [
          {
            "$ref": "#/components/parameters/GodParam"
          },
          {
            "$ref": "#/components/parameters/ExpandParam"
          },
          {
            "$ref": "#/components/parameters/PageParam"
          },
          {
            "$ref": "#/components/parameters/LimitParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Mandal counts or expanded hymn list"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },

    "/sungfor/{god}/meters": {
      "get": {
        "summary": "Get all meters used for singing to a god",
        "parameters": [
          {
            "$ref": "#/components/parameters/GodParam"
          },
          {
            "$ref": "#/components/parameters/ExpandParam"
          },
          {
            "$ref": "#/components/parameters/PageParam"
          },
          {
            "$ref": "#/components/parameters/LimitParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Meter counts or expanded meter list"
          }
        }
      }
    },

    "/sungfor/{god}/sungby": {
      "get": {
        "summary": "Get all poets that sang to a specific god",
        "parameters": [
          {
            "$ref": "#/components/parameters/GodParam"
          },
          {
            "$ref": "#/components/parameters/ExpandParam"
          },
          {
            "$ref": "#/components/parameters/PageParam"
          },
          {
            "$ref": "#/components/parameters/LimitParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Poet counts or expanded list"
          }
        }
      }
    },

    "/sungby/{poet}/mandals": {
      "get": {
        "summary": "Get all mandals that the hymns of a poet are included in",
        "parameters": [
          {
            "$ref": "#/components/parameters/PoetParam"
          },
          {
            "$ref": "#/components/parameters/ExpandParam"
          },
          {
            "$ref": "#/components/parameters/PageParam"
          },
          {
            "$ref": "#/components/parameters/LimitParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Mandal counts or expanded hymn list"
          }
        }
      }
    },

    "/sungby/{poet}/meters": {
      "get": {
        "summary": "Get all meters used by a specific poet",
        "parameters": [
          {
            "$ref": "#/components/parameters/PoetParam"
          },
          {
            "$ref": "#/components/parameters/ExpandParam"
          },
          {
            "$ref": "#/components/parameters/PageParam"
          },
          {
            "$ref": "#/components/parameters/LimitParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Meter counts or expanded meter list"
          }
        }
      }
    },

    "/sungby/{poet}/sungfor": {
      "get": {
        "summary": "Get all gods that a poet sang to",
        "parameters": [
          {
            "$ref": "#/components/parameters/PoetParam"
          },
          {
            "$ref": "#/components/parameters/ExpandParam"
          },
          {
            "$ref": "#/components/parameters/PageParam"
          },
          {
            "$ref": "#/components/parameters/LimitParam"
          }
        ],
        "responses": {
          "200": {
            "description": "God counts or expanded list"
          }
        }
      }
    },

    "/meters": {
      "get": {
        "summary": "Get all meter counts"
      }
    },

    "/sungforcategories": {
      "get": {
        "summary": "Get the counts for the categories of gods"
      }
    },

    "/sungbycategories": {
      "get": {
        "summary": "Get the counts for the categories of poets"
      }
    },

    "/pairs/{god}/{poet}": {
      "get": {
        "summary": "Get the hymns for a god-poet pair",
        "parameters": [
          {
            "$ref": "#/components/parameters/GodParam"
          },
          {
            "$ref": "#/components/parameters/PoetParam"
          },
          {
            "$ref": "#/components/parameters/PageParam"
          },
          {
            "$ref": "#/components/parameters/LimitParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Matching hymns"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },

    "/pairs/{godcategory}/{poetcategory}": {
      "get": {
        "summary": "Get the hymns for a god-category and poet-category pair",
        "parameters": [
          {
            "name": "godcategory",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/SungforCategory"
            }
          },
          {
            "name": "poetcategory",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/SungbyCategory"
            }
          },
          {
            "$ref": "#/components/parameters/PageParam"
          },
          {
            "$ref": "#/components/parameters/LimitParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Matching hymns"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },

    "/monologues": {
      "get": {
        "summary": "Get hymns where the poet is singing to their own self"
      }
    },

    "/conversations": {
      "get": {
        "summary": "Get hymns that have gods and poets talking with each other"
      }
    },

    "/godlist": {
      "get": {
        "summary": "List all gods"
      }
    },

    "/poetlist": {
      "get": {
        "summary": "List all poets"
      }
    },

    "/meterlist": {
      "get": {
        "summary": "List all meters"
      }
    },

    "/godcategorieslist": {
      "get": {
        "summary": "List all god categories"
      }
    },

    "/poetcategorieslist": {
      "get": {
        "summary": "List all poet categories"
      }
    }
  },

  "components": {
    "parameters": {
      "MandalParam": {
        "name": "n",
        "in": "path",
        "required": true,
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        }
      },

      "GodParam": {
        "name": "god",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      },

      "PoetParam": {
        "name": "poet",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      },

      "ExpandParam": {
        "name": "expand",
        "in": "query",
        "required": false,
        "schema": {
          "type": "boolean",
          "default": false
        }
      },

      "PageParam": {
        "name": "page",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        }
      },

      "LimitParam": {
        "name": "limit",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50,
          "default": 10
        }
      }
    },

    "responses": {
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },

      "MeterCounts": {
        "description": "Counts of poetic meters"
      },

      "GodCounts": {
        "description": "Counts of gods"
      },

      "PoetCounts": {
        "description": "Counts of poets"
      }
    },

    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "example": "Resource not found"
          }
        }
      },

      "HymnRef": {
        "type": "object",
        "properties": {
          "mandal": {
            "type": "integer"
          },
          "sukta": {
            "type": "integer"
          }
        }
      },

      "Meta": {
        "type": "object",
        "properties": {
          "mandal": {
            "type": "integer"
          },
          "sukta": {
            "type": "integer"
          },
          "meter": {
            "type": "string"
          },
          "sungby": {
            "type": "string"
          },
          "sungbycategory": {
            "$ref": "#/components/schemas/SungbyCategory"
          },
          "sungfor": {
            "type": "string"
          },
          "sungforcategory": {
            "$ref": "#/components/schemas/SungforCategory"
          }
        }
      },

      "SungbyCategory": {
        "type": "string",
        "enum": [
          "animal",
          "demon male",
          "divine female",
          "divine male",
          "human female",
          "human male"
        ]
      },

      "SungforCategory": {
        "type": "string",
        "enum": [
          "abstract",
          "animal",
          "demon male",
          "divine female",
          "divine human",
          "divine male",
          "human couple",
          "human female",
          "human male",
          "human unborn",
          "object",
          "plant"
        ]
      },

      "PaginatedResults": {
        "type": "object",
        "properties": {
          "total": {
            "type": "integer"
          },
          "pages": {
            "type": "integer"
          },
          "page": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {}
          }
        }
      }
    }
  }
}